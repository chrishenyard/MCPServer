{
  "AllowedHosts": "*",
  "CorsSettings": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "DetailedErrors": true,
  "SeqSettings": {
    "ServerUrl": "http://seq/ingest/otlp/v1/traces",
    "ApiKey": ""
  },
  "CSharpCodeSettings": {
    "SearchEndpoint": "http://localhost:9020/api/ask",
    "TopK": 10
  },
  "KeycloakSettings": {
    "Authority": "http://localhost:8080/realms/mcp_server",
    "ServerUrl": "http://localhost:5000",
    "Audience": "mcp_server_client",
    "RequireHttpsMetadata": false,
    "ClientId": "mcp_server_client",
    "ClientSecret": "",
    "MetadataAddress": "http://keycloak:8080/realms/mcp_server/.well-known/openid-configuration"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "McpServer"
    }
  }
}
